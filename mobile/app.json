{
  "expo": {
    "name": "PetPooja Owner",
    "slug": "msrm-owner",
    "scheme": "msrm-owner",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "description": "PetPooja Owner — Restaurant management dashboard for owners. Track sales, manage inventory, monitor staff, and run your restaurant business from anywhere.",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.petpooja.owner",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "PetPooja needs camera access to scan barcodes and capture product images.",
        "NSPhotoLibraryUsageDescription": "PetPooja needs photo library access to upload product and menu images.",
        "NSLocationWhenInUseUsageDescription": "PetPooja uses your location to identify your outlet and provide location-based insights.",
        "NSFaceIDUsageDescription": "Use Face ID to securely sign in to PetPooja.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.petpooja.owner",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@sentry/react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "934fae42-3d3a-4767-8bc1-a13992144aec"
      },
      "privacyPolicyUrl": "https://petpooja.com/privacy-policy"
    },
    "owner": "sunnyak47",
    "primaryColor": "#000000",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
