model ReportsCache {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id    String   @db.Uuid
  report_name  String   @db.VarChar(100)
  params_hash  String   @db.VarChar(64)
  data         Json
  generated_at DateTime @default(now()) @db.Timestamptz
  expires_at   DateTime @db.Timestamptz

  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted   Boolean  @default(false)

  outlet Outlet @relation(fields: [outlet_id], references: [id])

  @@unique([outlet_id, report_name, params_hash])
  @@map("reports_cache")
}

model DailySummary {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id        String   @db.Uuid
  summary_date     DateTime @db.Date
  total_orders     Int      @default(0)
  total_revenue    Decimal  @default(0) @db.Decimal(12, 2)
  total_tax        Decimal  @default(0) @db.Decimal(10, 2)
  total_discount   Decimal  @default(0) @db.Decimal(10, 2)
  dine_in_orders   Int      @default(0)
  takeaway_orders  Int      @default(0)
  delivery_orders  Int      @default(0)
  online_orders    Int      @default(0)
  cash_collected   Decimal  @default(0) @db.Decimal(12, 2)
  card_collected   Decimal  @default(0) @db.Decimal(12, 2)
  upi_collected    Decimal  @default(0) @db.Decimal(12, 2)
  other_collected  Decimal  @default(0) @db.Decimal(12, 2)
  covers           Int      @default(0)
  avg_order_value  Decimal  @default(0) @db.Decimal(10, 2)
  void_count       Int      @default(0)
  void_amount      Decimal  @default(0) @db.Decimal(10, 2)
  refund_count     Int      @default(0)
  refund_amount    Decimal  @default(0) @db.Decimal(10, 2)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz

  is_deleted       Boolean  @default(false)

  outlet Outlet @relation(fields: [outlet_id], references: [id])

  @@unique([outlet_id, summary_date])
  @@map("daily_summaries")
}

