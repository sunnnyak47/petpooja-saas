model OutletGroup {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  owner_id    String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted  Boolean  @default(false)

  @@map("outlet_groups")
}

model FranchiseConfig {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id           String    @db.Uuid
  franchise_fee_type  String    @default("percentage") @db.VarChar(20)
  franchise_fee_value Decimal   @default(0) @db.Decimal(10, 2)
  calculate_on        String    @default("gross") @db.VarChar(10)
  billing_cycle       String    @default("monthly") @db.VarChar(10)
  contract_start      DateTime? @db.Date
  contract_end        DateTime? @db.Date
  is_active           Boolean   @default(true)
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @default(now()) @updatedAt @db.Timestamptz
  is_deleted          Boolean   @default(false)

  outlet Outlet @relation(fields: [outlet_id], references: [id])

  @@map("franchise_config")
}

model CentralKitchenIndent {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesting_outlet_id  String    @db.Uuid
  ck_outlet_id          String    @db.Uuid
  indent_number         String    @unique @db.VarChar(30)
  status                String    @default("pending") @db.VarChar(20)
  total_items           Int       @default(0)
  notes                 String?
  requested_by          String?   @db.Uuid
  approved_by           String?   @db.Uuid
  approved_at           DateTime? @db.Timestamptz
  created_at            DateTime  @default(now()) @db.Timestamptz
  updated_at            DateTime  @default(now()) @updatedAt @db.Timestamptz
  is_deleted            Boolean   @default(false)

  requesting_outlet Outlet @relation("requesting_outlet", fields: [requesting_outlet_id], references: [id])
  ck_outlet         Outlet @relation("ck_outlet", fields: [ck_outlet_id], references: [id])
  items             CentralKitchenIndentItem[]

  @@map("central_kitchen_indents")
}

model CentralKitchenIndentItem {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  indent_id           String   @db.Uuid
  inventory_item_id   String   @db.Uuid
  requested_quantity  Decimal  @db.Decimal(10, 3)
  approved_quantity   Decimal? @db.Decimal(10, 3)
  dispatched_quantity Decimal? @db.Decimal(10, 3)
  unit                String   @db.VarChar(20)
  notes               String?
  created_at          DateTime @default(now()) @db.Timestamptz
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz

  indent         CentralKitchenIndent @relation(fields: [indent_id], references: [id])
  inventory_item InventoryItem        @relation(fields: [inventory_item_id], references: [id])

  @@map("central_kitchen_indent_items")
}

model SystemConfig {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key        String   @unique @db.VarChar(100)
  value      String   @db.Text
  is_deleted Boolean @default(false)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("system_configs")
}
model TallyMapping {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id         String   @db.Uuid
  pos_method        String   @db.VarChar(50) // cash, card, upi, etc.
  tally_ledger_name String   @db.VarChar(100)
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted        Boolean  @default(false)

  outlet Outlet @relation(fields: [outlet_id], references: [id])

  @@unique([outlet_id, pos_method])
  @@map("tally_mappings")
}

model Discount {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id             String    @db.Uuid
  name                  String    @db.VarChar(100)
  code                  String?   @db.VarChar(50)
  type                  String    @db.VarChar(20)         // percentage, flat, bogo, buy_x_get_y
  value                 Decimal   @default(0) @db.Decimal(10, 2)
  min_order_value       Decimal   @default(0) @db.Decimal(10, 2)
  max_discount          Decimal?  @db.Decimal(10, 2)
  applicable_on         String    @default("all") @db.VarChar(20) // all, category, item
  applicable_ids        Json      @default("[]")
  channels              Json      @default("[\"pos\",\"online\"]")
  start_date            DateTime? @db.Timestamptz
  end_date              DateTime? @db.Timestamptz
  is_active             Boolean   @default(true)
  auto_apply            Boolean   @default(false)
  max_uses              Int?
  max_uses_per_customer Int?
  priority              Int       @default(0)
  created_at            DateTime  @default(now()) @db.Timestamptz
  updated_at            DateTime  @default(now()) @updatedAt @db.Timestamptz
  is_deleted            Boolean   @default(false)

  outlet Outlet   @relation(fields: [outlet_id], references: [id])
  usages DiscountUsage[]

  @@index([outlet_id])
  @@index([code])
  @@map("discounts")
}

model DiscountUsage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  discount_id String   @db.Uuid
  order_id    String?  @db.Uuid
  customer_id String?  @db.Uuid
  amount      Decimal  @default(0) @db.Decimal(10, 2)
  created_at  DateTime @default(now()) @db.Timestamptz

  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted  Boolean  @default(false)

  discount Discount @relation(fields: [discount_id], references: [id])

  @@index([discount_id])
  @@map("discount_usages")
}
