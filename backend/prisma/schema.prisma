  is_deleted       Boolean   @default(false)

  outlet         Outlet         @relation(fields: [outlet_id], references: [id])
  order          Order          @relation(fields: [order_id], references: [id])
  processed_user User?          @relation(fields: [processed_by], references: [id])
  splits         PaymentSplit[]

  @@map("payments")
}

model PaymentSplit {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_id     String   @db.Uuid
  method         String   @db.VarChar(30)
  amount         Decimal  @db.Decimal(12, 2)
  transaction_id String?  @db.VarChar(100)
  status         String   @default("success") @db.VarChar(20)
  created_at     DateTime @default(now()) @db.Timestamptz

  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted     Boolean  @default(false)

  payment Payment @relation(fields: [payment_id], references: [id])

  @@map("payment_splits")
}

model TaxConfig {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id    String   @db.Uuid
  name         String   @db.VarChar(50)
  rate         Decimal  @db.Decimal(5, 2)
  type         String   @default("gst") @db.VarChar(10)
  is_inclusive  Boolean  @default(false)
  apply_on     String   @default("all") @db.VarChar(20)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted   Boolean  @default(false)

  outlet Outlet @relation(fields: [outlet_id], references: [id])

  @@map("tax_config")
}

model InvoiceSequence {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id       String   @db.Uuid
  financial_year  String   @db.VarChar(10)
  last_sequence   Int      @default(0)
  prefix          String?  @db.VarChar(20)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz

  outlet Outlet @relation(fields: [outlet_id], references: [id])

  @@unique([outlet_id, financial_year])
  @@map("invoice_sequences")
}

