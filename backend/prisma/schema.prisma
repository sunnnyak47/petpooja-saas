// ============================================
// PETPOOJA ERP — PRISMA SCHEMA
// Mirrors the PostgreSQL schema exactly
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE MODELS
// ============================================

model Role {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String           @unique @db.VarChar(50)
  display_name String           @db.VarChar(100)
  description  String?
  is_system    Boolean          @default(false)
  created_at   DateTime         @default(now()) @db.Timestamptz
  updated_at   DateTime         @default(now()) @updatedAt @db.Timestamptz
  is_deleted   Boolean          @default(false)

  role_permissions RolePermission[]
  user_roles       UserRole[]

  @@map("roles")
}

model Permission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key          String   @unique @db.VarChar(100)
  display_name String   @db.VarChar(150)
  module       String   @db.VarChar(50)
  description  String?
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted   Boolean  @default(false)

  role_permissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       String   @db.Uuid
  permission_id String   @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz

  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted    Boolean  @default(false)

  role       Role       @relation(fields: [role_id], references: [id])
  permission Permission @relation(fields: [permission_id], references: [id])

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}

model HeadOffice {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String   @db.VarChar(200)
  legal_name         String?  @db.VarChar(200)
  gstin              String?  @db.VarChar(15)
  gst_type           String?  @default("REGULAR") @db.VarChar(20)
  pan                String?  @db.VarChar(10)
  fssai              String?  @db.VarChar(20)
  fssai_expiry       DateTime? @db.Date
  contact_email      String   @unique @db.VarChar(150)
  contact_phone      String   @db.VarChar(15)
  whatsapp_number    String?  @db.VarChar(15)
  logo_url           String?  @db.VarChar(500)
  primary_color      String?  @default("#4F46E5") @db.VarChar(10)
  is_active          Boolean  @default(true)
  is_ac              Boolean  @default(false)
  serves_alcohol     Boolean  @default(false)
  service_charge_pct Decimal? @default(0) @db.Decimal(5, 2)
  gst_inclusive      Boolean  @default(false)
  default_gst_slab   String?  @default("5") @db.VarChar(10)
  language           String?  @default("en") @db.VarChar(20)
  zomato_id          String?  @db.VarChar(100)
  swiggy_id          String?  @db.VarChar(100)
  razorpay_key       String?  @db.VarChar(100)
  tally_enabled      Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted         Boolean  @default(false)
  plan               String   @default("TRIAL") @db.VarChar(50)
  setup_completed    Boolean  @default(false)
  metadata           Json?    @default("{}")
  outlets       Outlet[]
  subscriptions Subscription[]
  users         User[]         @relation("head_office_users")

  @@map("head_offices")
}

model Subscription {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  head_office_id  String    @db.Uuid
  plan_name       String    @db.VarChar(50)
  status          String    @default("active") @db.VarChar(20)
  billing_cycle   String    @default("monthly") @db.VarChar(20)
  amount          Decimal   @db.Decimal(10, 2)
  starts_at       DateTime  @default(now()) @db.Timestamptz
  expires_at      DateTime  @db.Timestamptz
  last_payment_at DateTime? @db.Timestamptz
  next_billing_at DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz

  head_office HeadOffice @relation(fields: [head_office_id], references: [id])

  @@map("subscriptions")
}

model Outlet {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  head_office_id          String?  @db.Uuid
  name                    String   @db.VarChar(200)
  code           String   @unique @db.VarChar(20)
  type           String   @default("restaurant") @db.VarChar(30)
  address_line1  String?  @db.VarChar(255)
  address_line2  String?  @db.VarChar(255)
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(100)
  pincode        String?  @db.VarChar(10)
  country        String   @default("India") @db.VarChar(50)
  phone          String?  @db.VarChar(15)
  email          String?  @db.VarChar(150)
  gstin          String?  @db.VarChar(20)
  fssai_number   String?  @db.VarChar(20)
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)
  timezone       String   @default("Asia/Kolkata") @db.VarChar(50)
  currency       String   @default("INR") @db.VarChar(5)
  is_ac          Boolean  @default(false)
  logo_url       String?  @db.VarChar(500)
  primary_color  String?  @db.VarChar(10)
  is_active      Boolean  @default(true)
  opening_time   DateTime? @db.Time
  closing_time   DateTime? @db.Time
  owner_id       String?  @db.Uuid
  tables_count   Int      @default(0)
  printer_type   String?  @default("THERMAL") @db.VarChar(30)
  printer_ip     String?  @db.VarChar(50)
  bill_header    String?  @db.Text
  bill_footer    String?  @db.Text
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted     Boolean  @default(false)
  metadata       Json?    @default("{}")
  user_roles              UserRole[]
  outlet_settings         OutletSetting[]
  audit_logs              AuditLog[]
  menu_categories         MenuCategory[]
  menu_items              MenuItem[]
  addon_groups            AddonGroup[]
  item_combos             ItemCombo[]
  table_areas             TableArea[]
  tables                  Table[]
  orders                  Order[]
  kot                     KOT[]
  table_reservations      TableReservation[]
  inventory_items         InventoryItem[]
  inventory_stock         InventoryStock[]
  stock_transactions      StockTransaction[]
  wastage_logs            WastageLog[]
  suppliers               Supplier[]
  purchase_orders         PurchaseOrder[]
  goods_received_notes    GoodsReceivedNote[]
  loyalty_transactions    LoyaltyTransaction[]
  campaigns               Campaign[]
  staff_profiles          StaffProfile[]
  staff_shifts            StaffShift[]
  attendance_logs         AttendanceLog[]
  staff_permissions       StaffPermission[]
  payment_methods_config  PaymentMethod[]
  payments                Payment[]
  tax_configs             TaxConfig[]
  invoice_sequences       InvoiceSequence[]
  reports_cache           ReportsCache[]
  daily_summaries         DailySummary[]
  franchise_config        FranchiseConfig[]
  outlet_menu_overrides   OutletMenuOverride[]
  ck_indents_requesting   CentralKitchenIndent[] @relation("requesting_outlet")
  ck_indents_ck           CentralKitchenIndent[] @relation("ck_outlet")
  tally_mappings          TallyMapping[]
  discounts               Discount[]
  head_office             HeadOffice?            @relation(fields: [head_office_id], references: [id])

  @@map("outlets")
}

model User {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  head_office_id        String?   @db.Uuid
  full_name             String    @db.VarChar(150)
  email                 String?   @unique @db.VarChar(150)
  phone                 String    @unique @db.VarChar(15)
  password_hash         String    @db.VarChar(255)
  avatar_url            String?   @db.VarChar(500)
  is_active             Boolean   @default(true)
  is_email_verified     Boolean   @default(false)
  is_phone_verified     Boolean   @default(false)
  last_login_at         DateTime? @db.Timestamptz
  failed_login_attempts Int       @default(0)
  locked_until          DateTime? @db.Timestamptz
  created_at            DateTime  @default(now()) @db.Timestamptz
  updated_at            DateTime  @default(now()) @updatedAt @db.Timestamptz
  is_deleted            Boolean   @default(false)
  reset_password_token  String?   @unique @db.VarChar(255)
  reset_password_expires DateTime? @db.Timestamptz

  user_roles       UserRole[]
  audit_logs       AuditLog[]
  orders_created   Order[]          @relation("staff_orders")
  orders_cancelled Order[]          @relation("cancelled_orders")
  orders_voided    Order[]          @relation("voided_orders")
  staff_profiles   StaffProfile[]
  attendance_logs  AttendanceLog[]
  staff_permissions StaffPermission[]
  payments_processed Payment[]
  head_office      HeadOffice?      @relation("head_office_users", fields: [head_office_id], references: [id])

  @@map("users")
}

model UserRole {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  role_id    String   @db.Uuid
  outlet_id  String?  @db.Uuid
  is_primary Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted Boolean  @default(false)

  user   User    @relation(fields: [user_id], references: [id])
  role   Role    @relation(fields: [role_id], references: [id])
  outlet Outlet? @relation(fields: [outlet_id], references: [id])

  @@unique([user_id, role_id, outlet_id])
  @@map("user_roles")
}

model OutletSetting {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id     String   @db.Uuid
  setting_key   String   @db.VarChar(100)
  setting_value String
  data_type     String   @default("string") @db.VarChar(20)
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted    Boolean  @default(false)

  outlet Outlet @relation(fields: [outlet_id], references: [id])

  @@unique([outlet_id, setting_key])
  @@map("outlet_settings")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?  @db.Uuid
  outlet_id   String?  @db.Uuid
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(50)
  entity_id   String?  @db.Uuid
  old_values  Json?
  new_values  Json?
  ip_address  String?  @db.VarChar(45)
  user_agent  String?
  metadata    Json?
  created_at  DateTime @default(now()) @db.Timestamptz

  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted  Boolean  @default(false)

  user   User?   @relation(fields: [user_id], references: [id])
  outlet Outlet? @relation(fields: [outlet_id], references: [id])

  @@map("audit_log")
}

// ============================================
// MENU MODELS
// ============================================

model MenuCategory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id     String   @db.Uuid
  name          String   @db.VarChar(100)
  description   String?
  icon_url      String?  @db.VarChar(500)
  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  parent_id     String?  @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted    Boolean  @default(false)

  outlet     Outlet        @relation(fields: [outlet_id], references: [id])
  parent     MenuCategory? @relation("category_parent", fields: [parent_id], references: [id])
  children   MenuCategory[] @relation("category_parent")
  menu_items MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id          String   @db.Uuid
  category_id        String   @db.Uuid
  name               String   @db.VarChar(200)
  description        String?
  short_code         String?  @db.VarChar(20)
  image_url          String?  @db.VarChar(500)
  base_price         Decimal  @db.Decimal(10, 2)
  food_type          String   @default("veg") @db.VarChar(15)
  cuisine            String?  @db.VarChar(50)
  kitchen_station    String   @default("KITCHEN") @db.VarChar(30)
  gst_rate           Decimal  @default(5.00) @db.Decimal(5, 2)
  hsn_code           String   @default("9963") @db.VarChar(10)
  is_active          Boolean  @default(true)
  is_available       Boolean  @default(true)
  is_bestseller      Boolean  @default(false)
  is_new             Boolean  @default(false)
  is_spicy           Boolean  @default(false)
  is_recommended     Boolean  @default(false)
  allergen_info      String?
  preparation_time_min Int    @default(15)
  calories           Int?
  display_order      Int      @default(0)
  tags               Json     @default("[]")
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted         Boolean  @default(false)
  external_id        String?  @db.VarChar(100)

  outlet         Outlet             @relation(fields: [outlet_id], references: [id])
  category       MenuCategory       @relation(fields: [category_id], references: [id])
  variants       ItemVariant[]
  addons         ItemAddon[]
  order_items    OrderItem[]
  menu_schedules MenuSchedule[]
  outlet_overrides OutletMenuOverride[]
  recipe         Recipe?
  combo_items    ComboItem[]

  @@map("menu_items")
}

model ItemVariant {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menu_item_id   String   @db.Uuid
  name           String   @db.VarChar(100)
  price_addition Decimal  @default(0) @db.Decimal(10, 2)
  is_default     Boolean  @default(false)
  is_active      Boolean  @default(true)
  display_order  Int      @default(0)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted     Boolean  @default(false)
  external_id    String?  @db.VarChar(100)

  menu_item   MenuItem    @relation(fields: [menu_item_id], references: [id])
  order_items OrderItem[]

  @@map("item_variants")
}

model AddonGroup {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id     String   @db.Uuid
  name          String   @db.VarChar(100)
  min_selection Int      @default(0)
  max_selection Int      @default(5)
  is_required   Boolean  @default(false)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted    Boolean  @default(false)

  outlet Outlet      @relation(fields: [outlet_id], references: [id])
  addons ItemAddon[]

  @@map("addon_groups")
}

model ItemAddon {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  addon_group_id String   @db.Uuid
  menu_item_id   String   @db.Uuid
  name           String   @db.VarChar(100)
  price          Decimal  @default(0) @db.Decimal(10, 2)
  is_active      Boolean  @default(true)
  display_order  Int      @default(0)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted     Boolean  @default(false)
  external_id    String?  @db.VarChar(100)

  addon_group      AddonGroup       @relation(fields: [addon_group_id], references: [id])
  menu_item        MenuItem         @relation(fields: [menu_item_id], references: [id])
  order_item_addons OrderItemAddon[]

  @@map("item_addons")
}

model ItemCombo {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id     String   @db.Uuid
  name          String   @db.VarChar(200)
  description   String?
  image_url     String?  @db.VarChar(500)
  combo_price   Decimal  @db.Decimal(10, 2)
  is_active     Boolean  @default(true)
  display_order Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted    Boolean  @default(false)

  outlet      Outlet      @relation(fields: [outlet_id], references: [id])
  combo_items ComboItem[]

  @@map("item_combo")
}

model ComboItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  combo_id     String   @db.Uuid
  menu_item_id String   @db.Uuid
  quantity     Int      @default(1)
  created_at   DateTime @default(now()) @db.Timestamptz

  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted Boolean  @default(false)

  combo     ItemCombo @relation(fields: [combo_id], references: [id])
  menu_item MenuItem  @relation(fields: [menu_item_id], references: [id])

  @@map("combo_items")
}

model MenuSchedule {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menu_item_id String   @db.Uuid
  day_of_week  Int?
  start_time   DateTime @db.Time
  end_time     DateTime @db.Time
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted   Boolean  @default(false)

  menu_item MenuItem @relation(fields: [menu_item_id], references: [id])

  @@map("menu_schedules")
}

model OutletMenuOverride {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id      String   @db.Uuid
  menu_item_id   String   @db.Uuid
  override_price Decimal? @db.Decimal(10, 2)
  is_available   Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted     Boolean  @default(false)

  outlet    Outlet   @relation(fields: [outlet_id], references: [id])
  menu_item MenuItem @relation(fields: [menu_item_id], references: [id])

  @@unique([outlet_id, menu_item_id])
  @@map("outlet_menu_overrides")
}

// ============================================
// ORDER MODELS
// ============================================

model TableArea {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id     String   @db.Uuid
  name          String   @db.VarChar(100)
  display_order Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted    Boolean  @default(false)

  outlet Outlet  @relation(fields: [outlet_id], references: [id])
  tables Table[]

  @@map("table_areas")
}

model Table {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id        String   @db.Uuid
  area_id          String?  @db.Uuid
  table_number     String   @db.VarChar(20)
  seating_capacity Int      @default(4)
  status           String   @default("available") @db.VarChar(20)
  current_order_id String?  @db.Uuid
  display_order    Int      @default(0)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz
  is_deleted       Boolean  @default(false)

  outlet       Outlet             @relation(fields: [outlet_id], references: [id])
  area         TableArea?         @relation(fields: [area_id], references: [id])
  orders       Order[]
  reservations TableReservation[]

  @@unique([outlet_id, table_number])
  @@map("tables")
}

model Order {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outlet_id          String    @db.Uuid
  order_number       String    @unique @db.VarChar(30)
  order_type         String    @default("dine_in") @db.VarChar(20)
  status             String    @default("created") @db.VarChar(25)
  table_id           String?   @db.Uuid
  customer_id        String?   @db.Uuid
  staff_id           String?   @db.Uuid
  subtotal           Decimal   @default(0) @db.Decimal(12, 2)
  discount_type      String?   @db.VarChar(15)
  discount_value     Decimal   @default(0) @db.Decimal(10, 2)
  discount_amount    Decimal   @default(0) @db.Decimal(10, 2)
  discount_reason    String?
  coupon_code        String?   @db.VarChar(50)
  loyalty_points_used Int      @default(0)
  loyalty_discount   Decimal   @default(0) @db.Decimal(10, 2)
  taxable_amount     Decimal   @default(0) @db.Decimal(12, 2)
  cgst               Decimal   @default(0) @db.Decimal(10, 2)
  sgst               Decimal   @default(0) @db.Decimal(10, 2)
  igst               Decimal   @default(0) @db.Decimal(10, 2)
  total_tax          Decimal   @default(0) @db.Decimal(10, 2)
  total_amount       Decimal   @default(0) @db.Decimal(12, 2)
  round_off          Decimal   @default(0) @db.Decimal(5, 2)
  grand_total        Decimal   @default(0) @db.Decimal(12, 2)
  notes              String?
  source             String    @default("pos") @db.VarChar(20)
  aggregator         String?   @db.VarChar(20)
  aggregator_order_id String?  @db.VarChar(100)
  is_paid            Boolean   @default(false)
  paid_at            DateTime? @db.Timestamptz
  cancelled_at       DateTime? @db.Timestamptz
  cancelled_by       String?   @db.Uuid
  cancel_reason      String?
  void_reason        String?
  voided_by          String?   @db.Uuid
  customer_name     String?   @db.VarChar(150)
  customer_phone    String?   @db.VarChar(15)
  delivery_address  String?
  invoice_number     String?   @db.VarChar(50)
  invoice_url        String?   @db.VarChar(500)
  daily_sequence     Int?
  created_at         DateTime  @default(now()) @db.Timestamptz
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamptz
  is_deleted         Boolean   @default(false)

  outlet         Outlet             @relation(fields: [outlet_id], references: [id])
  table          Table?             @relation(fields: [table_id], references: [id])
  customer       Customer?          @relation(fields: [customer_id], references: [id])
  staff          User?              @relation("staff_orders", fields: [staff_id], references: [id])
  cancelled_user User?              @relation("cancelled_orders", fields: [cancelled_by], references: [id])
  voided_user    User?              @relation("voided_orders", fields: [voided_by], references: [id])
  order_items    OrderItem[]
  status_history OrderStatusHistory[]
  kots           KOT[]
  payments       Payment[]
  loyalty_txns   LoyaltyTransaction[]

  @@map("orders")
}

model OrderItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String   @db.Uuid
  menu_item_id    String   @db.Uuid
  variant_id      String?  @db.Uuid
  name            String   @db.VarChar(200)
  variant_name    String?  @db.VarChar(100)
  quantity        Int      @default(1)
  unit_price      Decimal  @db.Decimal(10, 2)
