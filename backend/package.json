{
  "name": "petpooja-erp-backend",
  "version": "1.0.0",
  "description": "Petpooja Restaurant ERP — Production Backend API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:load": "artillery run tests/artillery.yml",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:validate": "npx prisma validate",
    "prisma:seed": "node prisma/seed.js",
    "lint": "eslint src/",
    "db:schema": "psql $DATABASE_URL -f src/database/schema.sql",
    "db:seed": "psql $DATABASE_URL -f src/database/seed.sql"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.685.0",
    "@aws-sdk/s3-request-presigner": "^3.685.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.3",
    "axios": "^1.14.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.1",
    "fast-csv": "^5.0.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "puppeteer": "^23.6.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.4",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "artillery": "^2.0.21",
    "eslint": "^9.13.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prisma": "^6.19.3",
    "supertest": "^7.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
