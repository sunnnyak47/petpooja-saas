# ============================================
# PETPOOJA ERP — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in values
# ============================================

# App
NODE_ENV=development
PORT=5001
APP_NAME=Petpooja ERP
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3001
KITCHEN_URL=http://localhost:3002

# Database — PostgreSQL 16
DATABASE_URL="postgresql://postgres:Qwaszx%40123%24%244%25@db.mddgruyvajrmolbocdsp.supabase.co:5432/postgres"

# Redis 7
REDIS_URL=redis://:redis_secret@localhost:6379

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_minimum_256_bits_long_change_this_in_production_now
JWT_ACCESS_SECRET=your_super_secret_jwt_key_minimum_256_bits_long_change_this_in_production_now
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_256_bits_long_change_this_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS S3 + CloudFront
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=petpooja-erp-assets
AWS_CLOUDFRONT_URL=https://d1234567890.cloudfront.net

# Payment Gateways
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
PAYTM_MID=your_paytm_merchant_id
PAYTM_MERCHANT_KEY=your_paytm_merchant_key

# Pine Labs POS Terminal
PINE_LABS_API_URL=https://api.pluralonline.com
PINE_LABS_MERCHANT_ID=your_pine_labs_merchant_id
PINE_LABS_ACCESS_CODE=your_pine_labs_access_code

# UrbanPiper (Zomato/Swiggy integration)
URBANPIPER_API_URL=https://api.urbanpiper.com
URBANPIPER_USERNAME=your_urbanpiper_username
URBANPIPER_API_KEY=your_urbanpiper_api_key

# Tally ERP Sync
TALLY_SERVER_URL=http://localhost:9000

# SMS — MSG91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=PETPJA
MSG91_TEMPLATE_ID=your_msg91_template_id

# Email — SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@petpooja.com

# Monitoring
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# CORS — Whitelist (comma-separated)
CORS_WHITELIST=http://localhost:3001,http://localhost:3002,http://localhost:3000

# Rate Limiting
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=5
RATE_LIMIT_WINDOW_MS=60000

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Bcrypt
BCRYPT_ROUNDS=12
