# ====================================================================
# PETPOOJA ERP — Environment Configuration
# Copy to .env and fill in your values
# ====================================================================

# Server
NODE_ENV=production
PORT=5001

# Database (PostgreSQL 16)
# For Supabase, use the Session Pooler URL (Port 6543) with ?pgbouncer=true to avoid IPv6 issues.
DATABASE_URL=postgresql://postgres:password@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Redis 7
REDIS_URL=redis://:your_redis_password@localhost:6379

# JWT (MINIMUM 256-bit secrets — generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=CHANGE_ME_TO_A_64_CHAR_HEX_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_A_DIFFERENT_64_CHAR_HEX_STRING
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_WHITELIST=http://localhost:3001,http://localhost:3002

# Bcrypt
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=5

# AWS S3 (file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=petpooja-uploads
AWS_CLOUDFRONT_URL=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Pine Labs
PINELABS_MERCHANT_ID=
PINELABS_SECURITY_TOKEN=
PINELABS_STORE_ID=

# Aggregator Webhooks
SWIGGY_WEBHOOK_SECRET=
SWIGGY_API_URL=https://partner-api.swiggy.com
SWIGGY_API_KEY=
ZOMATO_WEBHOOK_SECRET=
ZOMATO_API_URL=https://api.zomato.com
ZOMATO_API_KEY=

# SMS (MSG91)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=PETPJA
MSG91_TEMPLATE_ID=
MSG91_OTP_TEMPLATE=

# WhatsApp Business API (Meta)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Loyalty
LOYALTY_EARN_RATIO=100
LOYALTY_REDEEM_VALUE=1
LOYALTY_MIN_REDEEM=50
