{
  "name": "petpooja-erp-desktop",
  "version": "2.0.3",
  "description": "Petpooja ERP — Restaurant Management Desktop App",
  "main": "src/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run frontend\" \"wait-on http://localhost:3001 && electron .\"",
    "frontend": "cd ../frontend && npm run dev",
    "postinstall": "electron-builder install-app-deps",
    "sync-frontend": "node -e \"const fs=require('fs'); fs.rmSync('frontend-dist',{recursive:true,force:true}); fs.cpSync('../frontend/dist','frontend-dist',{recursive:true}); console.log('frontend-dist synced')\"",
    "prebuild:mac": "npm run sync-frontend",
    "prebuild:win": "npm run sync-frontend",
    "prebuild:all": "npm run sync-frontend",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac",
    "pack": "electron-builder --dir",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "build": {
    "appId": "com.petpoojaerp.app",
    "productName": "MS-RM System",
    "copyright": "Copyright 2026 Madsun Digital Marketing & Media Agency",
    "afterSign": "build/afterSign.js",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "extraResources": [
      {
        "from": "frontend-dist",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "publisherName": "Petpooja ERP"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Petpooja ERP",
      "installerIcon": "assets/icon.png",
      "uninstallerIcon": "assets/icon.png",
      "language": "1033"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "minimumSystemVersion": "10.13.0",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "MS-RM System uses the microphone to capture spoken restaurant orders in Voice POS."
      }
    },
    "dmg": {
      "title": "Install MS-RM System",
      "icon": "assets/icon.icns",
      "background": null,
      "contents": [
        {
          "x": 150,
          "y": 200,
          "type": "file"
        },
        {
          "x": 390,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 400
      }
    },
    "publish": {
      "provider": "github",
      "owner": "sunnnyak47",
      "repo": "petpooja-saas",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "node-thermal-printer": "^4.3.2"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "wait-on": "^7.0.0"
  }
}
