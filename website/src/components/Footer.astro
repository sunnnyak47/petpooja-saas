---
import { SITE, FEATURES, SOLUTIONS, SUPPORT } from '../data/site';
const cols = [
  { title: 'Product', links: [
    ...FEATURES.slice(0, 5).map((f) => ({ label: f.name, href: `/features/${f.slug}` })),
    { label: 'Payments', href: '/payments' }, { label: 'Hardware', href: '/hardware' },
  ]},
  { title: 'Solutions', links: SOLUTIONS.map((s) => ({ label: s.name, href: `/solutions/${s.slug}` })) },
  { title: 'Resources', links: [
    { label: 'How it works', href: '/how-it-works' }, { label: 'Compare', href: '/compare' },
    { label: 'Blog', href: '/blog' }, { label: 'Case Studies', href: '/case-studies' },
    { label: 'Migration', href: '/migration' }, { label: 'Integrations', href: '/integrations' }, { label: 'Security', href: '/security' },
  ]},
  { title: 'Company', links: [
    { label: 'About', href: '/about' }, { label: 'Pricing', href: '/pricing' }, { label: 'Contact', href: '/demo' },
    { label: 'Privacy', href: '/privacy' }, { label: 'Terms', href: '/terms' },
  ]},
];
---
<footer class="mt-24 border-t border-line bg-surface-alt">
  <div class="container-x py-14 grid gap-10 md:grid-cols-[1.3fr_repeat(4,1fr)]">
    <div>
      <div class="flex items-center gap-2 font-extrabold text-lg">
        <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-600 text-white">M</span>{SITE.name}
      </div>
      <p class="mt-3 text-sm text-ink-mute max-w-xs">{SITE.tagline}. Built for restaurants across Australia.</p>
    </div>
    {cols.map((c) => (
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-ink-mute mb-3">{c.title}</h4>
        <ul class="space-y-2">
          {c.links.map((l) => <li><a href={l.href} class="text-sm text-ink-soft hover:text-brand-700">{l.label}</a></li>)}
        </ul>
      </div>
    ))}
  </div>
  <div class="border-t border-line">
    <div class="container-x py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-ink-mute">
      <span>© {new Date().getFullYear()} {SITE.name}.{SUPPORT.abn ? ` ABN ${SUPPORT.abn}.` : ''} All rights reserved.</span>
      <span>🇦🇺 Proudly built for Australian restaurants</span>
    </div>
  </div>
</footer>
