---
// Product screenshot. Prefers the Australian variant (public/screenshots/au/<name>)
// and falls back to the base image if no AU-specific shot exists.
import fs from 'node:fs';
const { name, alt = '', eager = false, frame = true } = Astro.props;
const hasAu = fs.existsSync(`./public/screenshots/au/${name}`);
const src = hasAu ? `/screenshots/au/${name}` : `/screenshots/${name}`;
const imgCls = `w-full ${frame ? 'rounded-xl border border-line' : ''}`;
const loading = eager ? 'eager' : 'lazy';
---
<img src={src} alt={alt} width="1440" height="900" loading={loading} class={imgCls} />
