---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';
import Shot from '../components/Shot.astro';
import { FEATURES, REGIONS, CASE_STUDIES } from '../data/site';
const stats = [
  { v: '12+', l: 'Integrated modules' },
  { v: '<1s', l: 'POS load time' },
  { v: '99.9%', l: 'Uptime' },
  { v: '🇦🇺', l: 'Made for Australia' },
];
const whys = [
  ['spark', 'Stop juggling apps', 'POS, kitchen, inventory, delivery and books in one place — no more switching tabs or re-keying.'],
  ['chart', 'Real-time, everywhere', 'A sale on the POS updates stock, the kitchen screen, reports and end-of-day instantly.'],
  ['shield', 'Built for Australia', 'GST & BAS, Xero/MYOB, EFTPOS and the right delivery apps — compliant out of the box.'],
];
---
<Layout>
  <!-- 1. Hero -->
  <div class="relative overflow-hidden hero-aura">
    <div class="absolute inset-0 bg-dotgrid pointer-events-none" aria-hidden="true"></div>
    <section class="container-x relative pt-16 pb-14 lg:pt-24 lg:pb-20 grid lg:grid-cols-[1.05fr_1fr] gap-12 items-center">
      <div>
        <span class="eyebrow">Restaurant management platform</span>
        <h1 class="h1 mt-3">Run your whole restaurant<br class="hidden sm:block"/> on <span class="text-gradient-brand">one platform</span>.</h1>
        <p class="lead mt-5 max-w-xl">
          POS, kitchen display, inventory, online orders and accounting — unified, real-time, and
          built for Australia. Stop juggling apps and spreadsheets.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/demo" class="btn-primary btn-lg">Book a Demo</a>
          <a href="/pricing" class="btn-outline btn-lg">See Pricing</a>
        </div>
        <ul class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-ink-mute">
          <li class="inline-flex items-center gap-1.5"><Icon name="check" class="w-4 h-4 text-brand-600"/> No credit card to start</li>
          <li class="inline-flex items-center gap-1.5"><Icon name="check" class="w-4 h-4 text-brand-600"/> Live in a day</li>
          <li class="inline-flex items-center gap-1.5"><Icon name="check" class="w-4 h-4 text-brand-600"/> Works fully offline</li>
        </ul>
        <p class="mt-5 text-sm text-ink-mute">
          Switching from <strong>Square</strong> or <strong>Lightspeed</strong>? <a href="/migration" class="font-medium text-brand-700 hover:underline">We move you over →</a>
        </p>
      </div>
      <div class="browser-frame">
        <div class="browser-bar">
          <span class="browser-dot bg-red-400/70"></span>
          <span class="browser-dot bg-amber-400/70"></span>
          <span class="browser-dot bg-emerald-400/70"></span>
          <span class="ml-3 hidden sm:block text-xs text-ink-mute">app.msrm.com/dashboard</span>
        </div>
        <Shot name="dashboard.webp" alt="MSRM owner dashboard — live orders, tables, kitchen and revenue at a glance" eager={true} frame={false} />
      </div>
    </section>
  </div>

  <!-- 2. Trust band -->
  <section class="border-y border-line bg-surface-alt">
    <div class="container-x py-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-3 text-sm">
      <span class="font-semibold text-ink-soft">Trusted by restaurants across Australia</span>
      <span class="chip">QSR</span><span class="chip">Fine Dine</span><span class="chip">Cloud Kitchen</span><span class="chip">Café</span><span class="chip">Chains</span>
    </div>
  </section>

  <!-- 3. Problem → solution -->
  <section class="container-x py-16 lg:py-20">
    <div class="text-center max-w-2xl mx-auto">
      <span class="eyebrow">Why MSRM</span>
      <h2 class="h2 mt-2">Everything your restaurant needs, built in.</h2>
      <p class="lead mt-3">No patchwork of third-party apps — one system from first order to end-of-day close.</p>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {whys.map(([ic, t, d]) => (
        <div class="card">
          <div class="feature-tile"><Icon name={ic} class="w-6 h-6" /></div>
          <h3 class="mt-4 font-semibold text-lg">{t}</h3>
          <p class="mt-2 text-ink-soft">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- 4. Core feature grid -->
  <section class="container-x py-8">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {FEATURES.map((f) => (
        <a href={`/features/${f.slug}`} class="card-link group">
          <div class="feature-tile"><Icon name={f.icon} class="w-6 h-6" /></div>
          <h3 class="mt-4 font-semibold text-lg flex items-center gap-1">{f.name}<Icon name="arrow" class="w-4 h-4 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition text-brand-600" /></h3>
          <p class="mt-2 text-ink-soft text-[15px]">{f.blurb}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- 5. Built for Australia band -->
  <section class="container-x py-16 lg:py-20">
    <div class="text-center max-w-2xl mx-auto mb-8">
      <span class="eyebrow">Local by design</span>
      <h2 class="h2 mt-2">Built for Australian restaurants</h2>
      <p class="lead mt-3">The right taxes, payments and delivery apps for the Australian market — no plugins, no workarounds.</p>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {[
        ['ledger', 'Tax & compliance', `${REGIONS.au.tax}, plus Single Touch Payroll — ATO-ready.`],
        ['pos', 'Payments', `${REGIONS.au.pay}.`],
        ['bag', 'Delivery apps', `${REGIONS.au.aggregators.join(', ')} — plus commission-free QR ordering.`],
      ].map(([ic, t, d]) => (
        <div class="card">
          <div class="feature-tile"><Icon name={ic} class="w-6 h-6" /></div>
          <h3 class="mt-4 font-semibold text-lg">{t}</h3>
          <p class="mt-2 text-ink-soft">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- 6. Stats -->
  <section class="container-x">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {stats.map((s) => (
        <div class="card text-center"><div class="text-3xl font-extrabold text-gradient-brand">{s.v}</div><div class="text-sm text-ink-mute mt-1">{s.l}</div></div>
      ))}
    </div>
  </section>

  <!-- 7. Testimonials -->
  <section class="container-x py-16 lg:py-20">
    <div class="text-center max-w-2xl mx-auto mb-8">
      <span class="eyebrow">What owners say</span>
      <h2 class="h2 mt-2">Built for real Australian venues.</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {CASE_STUDIES.map((c) => (
        <figure class="card flex flex-col">
          <div class="text-4xl leading-none text-brand-300 font-serif" aria-hidden="true">“</div>
          <blockquote class="-mt-2 text-[15px] text-ink-soft leading-relaxed flex-1">{c.quote}</blockquote>
          <figcaption class="mt-4 pt-4 border-t border-line text-sm"><span class="font-semibold">{c.name}</span><span class="text-ink-mute"> · {c.type}</span></figcaption>
        </figure>
      ))}
    </div>
    <p class="text-center text-xs text-ink-mute mt-4">Representative examples — named, verified customer stories will replace these as venues go live.</p>
  </section>

  <!-- 8. Local support / onboarding band -->
  <section class="container-x pb-4">
    <div class="rounded-xl2 border border-line bg-surface-alt p-8 lg:p-10 grid lg:grid-cols-[1.1fr_1fr] gap-8 items-center">
      <div>
        <span class="eyebrow">Australian support</span>
        <h2 class="h2 mt-2">We set you up — and stay on.</h2>
        <p class="lead mt-3">Switching systems is the scary part. We migrate your menu, tables and staff, keep your delivery apps running, and are on hand through your first shifts — not an offshore ticket queue.</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/migration" class="btn-outline">How migration works</a>
          <a href="/demo" class="btn-primary">Talk to our team</a>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {[['Live in a day', 'Most single venues'], ['Zero downtime', 'Parallel run + cutover'], ['We migrate you', 'Menu, tables & staff'], ['Real people', 'Onboarding that stays on']].map(([v, l]) => (
          <div class="card text-center py-5">
            <div class="text-lg font-extrabold text-brand-700">{v}</div>
            <div class="text-xs text-ink-mute mt-1">{l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>
