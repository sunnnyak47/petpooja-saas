---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';
const types = [
  { name: 'QSR & Fast Food', need: 'Speed & throughput', feats: ['pos', 'kds', 'online-orders'] },
  { name: 'Fine Dine', need: 'Table service & experience', feats: ['pos', 'multi-outlet', 'analytics'] },
  { name: 'Cloud Kitchen', need: 'Delivery-only, many brands', feats: ['online-orders', 'kds', 'inventory'] },
  { name: 'Café & Bakery', need: 'Quick counter + stock', feats: ['pos', 'inventory', 'analytics'] },
  { name: 'Chains & Franchises', need: 'Central control', feats: ['multi-outlet', 'accounting', 'analytics'] },
];
---
<Layout title="Solutions" description="MSRM for QSR, fine dine, cloud kitchens, cafés and chains — across India and Australia.">
  <section class="container-x pt-16 pb-8 text-center max-w-2xl mx-auto">
    <span class="eyebrow">Solutions</span>
    <h1 class="h1 text-4xl sm:text-5xl mt-3">Built for how you run.</h1>
    <p class="lead mt-4">Whatever your format or market, MSRM adapts — same platform, the right modules for you.</p>
  </section>

  <section class="container-x grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {types.map((t) => (
      <div class="card">
        <h3 class="font-semibold text-lg">{t.name}</h3>
        <p class="text-sm text-ink-mute mt-1">{t.need}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {t.feats.map((f) => <a href={`/features/${f}`} class="chip hover:border-brand-400 hover:text-brand-700">{f.replace('-', ' ')}</a>)}
        </div>
      </div>
    ))}
  </section>

  <section class="container-x py-16 grid md:grid-cols-2 gap-6">
    <div class="card"><div class="text-3xl">🇮🇳</div><h3 class="h2 text-2xl mt-2">India</h3><p class="mt-2 text-ink-soft">GST &amp; e-invoicing, UPI/Razorpay, Swiggy, Zomato &amp; ONDC, multi-language voice POS.</p><a href="/features/accounting" class="mt-3 inline-flex items-center gap-1 text-brand-700 font-semibold">Compliance details <Icon name="arrow" class="w-4 h-4" /></a></div>
    <div class="card"><div class="text-3xl">🇦🇺</div><h3 class="h2 text-2xl mt-2">Australia</h3><p class="mt-2 text-ink-soft">GST, BAS &amp; Xero, payroll, EFTPOS/Square/Stripe, Uber Eats, DoorDash &amp; Menulog, weekend surcharge.</p><a href="/features/accounting" class="mt-3 inline-flex items-center gap-1 text-brand-700 font-semibold">Compliance details <Icon name="arrow" class="w-4 h-4" /></a></div>
  </section>
  <CTA />
</Layout>
