---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';

// Capability comparison — categories, not named brands (avoids misleading-conduct risk).
const COLS = ['MSRM', 'Typical cloud POS', 'Legacy hospitality POS'];
const ROWS = [
  ['All-in-one — one price', 'yes', 'addon', 'module'],
  ['Delivery apps built in (Uber Eats · DoorDash · Menulog)', 'yes', 'middleware', 'addon'],
  ['Net margin per channel (commission reconciliation)', 'yes', 'no', 'limited'],
  ['Auto-86 across every channel', 'yes', 'no', 'limited'],
  ['Offline mode (keep selling without internet)', 'yes', 'limited', 'yes'],
  ['GST, BAS & Xero', 'yes', 'addon', 'addon'],
  ['Payroll', 'yes', 'no', 'addon'],
  ['Split bill & multi-tender', 'yes', 'limited', 'yes'],
  ['Own QR ordering (zero commission)', 'yes', 'addon', 'limited'],
  ['Multi-outlet central control', 'yes', 'limited', 'yes'],
  ['Live in a day', 'yes', 'yes', 'weeks'],
  ['Zero-downtime migration', 'yes', 'na', 'na'],
];
const CELL = {
  yes:        { t: '✓',           c: '#16a34a', w: 700 },
  no:         { t: '—',           c: '#94a3b8', w: 400 },
  limited:    { t: 'Limited',     c: '#f59e0b', w: 500 },
  addon:      { t: 'Paid add-on', c: '#f59e0b', w: 500 },
  middleware: { t: 'Via middleware', c: '#f59e0b', w: 500 },
  module:     { t: 'Module-by-module', c: '#f59e0b', w: 500 },
  weeks:      { t: 'Weeks',       c: '#94a3b8', w: 400 },
  na:         { t: '—',           c: '#94a3b8', w: 400 },
};

const pains = [
  ['Add-on creep', 'You pay for the POS — then again for delivery, accounting, loyalty and payroll. The bill balloons.'],
  ['Aggregator tablet chaos', 'A separate tablet per delivery app, re-keyed into the till. Mistakes and missed orders.'],
  ['No real margin view', 'You see gross delivery sales, never the net after 20–30% commission. So you can’t tell what actually pays.'],
];

// One narrated walkthrough (public/video/tour.mp4). `at` = start second of each
// chapter inside the single video — used to seek when a step is clicked.
const chapters = [
  { n: 1, at: 0,    title: 'Go live in a day', text: 'Add your menu, tables and team — and you’re taking orders the same afternoon. No consultants.' },
  { n: 2, at: 7.9,  title: 'Take an order', text: 'Touch POS, split the bill, part cash and part card, and fire it straight to the kitchen.' },
  { n: 3, at: 16.5, title: 'All your delivery apps, one screen', text: 'Uber Eats, DoorDash and Menulog land beside your dine-in orders — no more juggling tablets.' },
  { n: 4, at: 25.4, title: 'Know your real margin', text: 'Every channel side by side: gross sales, commission, and the net that actually hits your account.' },
  { n: 5, at: 33.0, title: 'Close the day in one click', text: 'Sales, payments and GST reconciled and ready for BAS and Xero — in one click.' },
];

const whyAU = [
  ['Commission clarity', 'Net-after-commission per channel + payout reconciliation. Know which app actually pays.'],
  ['BAS & Xero, sorted', 'GST, BAS and Xero sync built in — your books keep themselves.'],
  ['Surcharge ready', 'Weekend and public-holiday surcharge, applied automatically and shown on the receipt.'],
  ['Never stops selling', 'Offline-first POS keeps trading when the internet drops, then syncs.'],
];
---
<Layout title="Why MSRM vs other POS (Australia)" description="Why Australian restaurants choose MSRM over a typical cloud POS or a legacy hospitality system — one platform, delivery apps built in, real margin clarity, BAS & Xero.">
  <!-- Hero -->
  <section class="container-x pt-16 pb-8 text-center max-w-3xl mx-auto">
    <span class="eyebrow">Why MSRM · Australia 🇦🇺</span>
    <h1 class="h1 text-4xl sm:text-5xl mt-3">The all-in-one POS Australian restaurants switch to.</h1>
    <p class="lead mt-4">POS, kitchen, delivery apps, stock and your BAS — one platform, one price. Not a POS plus a stack of paid add-ons.</p>
    <div class="mt-6 flex justify-center gap-3"><a href="/demo" class="btn-primary">Book a Demo</a><a href="#see-it" class="btn-outline">Watch how it works</a></div>
  </section>

  <!-- Pain -->
  <section class="container-x py-12">
    <div class="text-center max-w-2xl mx-auto"><span class="eyebrow">The hidden cost of a typical POS</span><h2 class="h2 mt-2">Three things that quietly cost you.</h2></div>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      {pains.map(([t, d]) => (<div class="card"><h3 class="font-semibold text-lg">{t}</h3><p class="mt-2 text-ink-soft">{d}</p></div>))}
    </div>
  </section>

  <!-- Comparison table -->
  <section class="container-x py-8">
    <div class="text-center max-w-2xl mx-auto"><span class="eyebrow">Honest comparison</span><h2 class="h2 mt-2">MSRM vs the rest.</h2></div>
    <div class="mt-8 overflow-x-auto rounded-xl2 border border-line">
      <table class="w-full text-sm bg-white min-w-[640px]">
        <thead>
          <tr class="border-b border-line">
            <th class="text-left p-4 font-semibold w-[44%]">Capability</th>
            {COLS.map((c, i) => (
              <th class="p-4 text-center font-bold" style={i === 0 ? 'color:#2563eb' : 'color:var(--ink-mute,#64748b)'}>{c}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {ROWS.map((r) => (
            <tr class="border-b border-line last:border-0">
              <td class="p-4 text-ink-soft">{r[0]}</td>
              {r.slice(1).map((v) => { const c = CELL[v]; return (
                <td class="p-4 text-center" style={`color:${c.c};font-weight:${c.w}`}>{c.t}</td>
              ); })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-xs text-ink-mute mt-3">Compared by capability category, not specific brands. Some systems offer some of these as paid add-ons or third-party integrations.</p>
  </section>

  <!-- ★ Visualisation section — one narrated walkthrough -->
  <section id="see-it" class="container-x py-16">
    <div class="text-center max-w-2xl mx-auto">
      <span class="eyebrow">See exactly how it works</span>
      <h2 class="h2 mt-2">One restaurant, one platform — in 40 seconds.</h2>
      <p class="lead mt-3">A narrated walkthrough of a full day on MSRM, from go-live to end-of-day. <span class="font-semibold text-brand-700">Sound on 🔊</span> — or jump to any step.</p>
    </div>
    <div class="mt-10 grid lg:grid-cols-3 gap-8 items-start">
      <div class="lg:col-span-2 card p-2 shadow-lift">
        <video id="tour" class="rounded-xl w-full border border-line bg-black" controls playsinline preload="metadata" poster="/screenshots/au/dashboard.webp">
          <source src="/video/tour.mp4" type="video/mp4" />
          Your browser doesn’t support video — <a href="/video/tour.mp4" class="underline">download the walkthrough</a>.
        </video>
      </div>
      <ol class="space-y-2">
        {chapters.map((ch) => (
          <li>
            <button type="button" class="chapter-btn w-full text-left flex gap-3 rounded-xl border border-line p-3 hover:border-brand-400 transition" data-at={ch.at}>
              <span class="chapter-n grid h-7 w-7 shrink-0 place-items-center rounded-full bg-brand-50 text-brand-700 text-sm font-bold">{ch.n}</span>
              <span>
                <span class="block font-semibold leading-tight">{ch.title}</span>
                <span class="block text-sm text-ink-soft mt-0.5">{ch.text}</span>
              </span>
            </button>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Why AU -->
  <section class="container-x py-12">
    <h2 class="h2 text-2xl text-center">Built for Australian restaurants</h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {whyAU.map(([t, d]) => (
        <div class="card"><div class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="check" class="w-5 h-5" /></div><h3 class="mt-3 font-semibold">{t}</h3><p class="mt-1 text-sm text-ink-soft">{d}</p></div>
      ))}
    </div>
  </section>

  <!-- Migration + pricing -->
  <section class="container-x pb-8 grid md:grid-cols-2 gap-5">
    <a href="/migration" class="card hover:border-brand-400 transition"><h3 class="font-semibold text-lg">Switch without the risk →</h3><p class="mt-2 text-ink-soft">Move from your current POS with zero downtime. Your delivery apps stay live through the cutover.</p></a>
    <a href="/pricing" class="card hover:border-brand-400 transition"><h3 class="font-semibold text-lg">One simple price →</h3><p class="mt-2 text-ink-soft">Per-outlet pricing with everything included — no add-on surprises.</p></a>
  </section>

  <CTA title="See why AU restaurants switch to MSRM" />

  <script>
    // Click a step → seek the single walkthrough video to that chapter and play.
    const video = document.getElementById('tour');
    const btns = Array.from(document.querySelectorAll('.chapter-btn'));
    const marks = btns.map((b) => parseFloat(b.getAttribute('data-at')));
    const highlight = (i) => btns.forEach((b, j) => {
      b.classList.toggle('border-brand-400', j === i);
      b.querySelector('.chapter-n').classList.toggle('bg-brand-600', j === i);
      b.querySelector('.chapter-n').classList.toggle('text-white', j === i);
      b.querySelector('.chapter-n').classList.toggle('bg-brand-50', j !== i);
      b.querySelector('.chapter-n').classList.toggle('text-brand-700', j !== i);
    });
    btns.forEach((btn, i) => btn.addEventListener('click', () => {
      if (!video) return;
      video.currentTime = marks[i];
      highlight(i);
      video.play().catch(() => {});
    }));
    // Keep the active step highlighted as the video plays.
    video?.addEventListener('timeupdate', () => {
      let i = 0;
      for (let k = 0; k < marks.length; k++) if (video.currentTime >= marks[k] - 0.3) i = k;
      highlight(i);
    });
  </script>
</Layout>
