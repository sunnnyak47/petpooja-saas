---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';
import { FEATURES } from '../data/site';
const groups = [...new Set(FEATURES.map((f) => f.group))];
---
<Layout title="Features" description="Every module of MSRM — POS, kitchen display, inventory, online orders, accounting, analytics and multi-outlet.">
  <section class="container-x pt-16 pb-8 text-center max-w-2xl mx-auto">
    <span class="eyebrow">Features</span>
    <h1 class="h1 mt-3 text-4xl sm:text-5xl">One platform, every module.</h1>
    <p class="lead mt-4">From the first tap on the POS to the end-of-day close — explore what runs your restaurant.</p>
  </section>
  {groups.map((g) => (
    <section class="container-x py-6">
      <h2 class="text-sm font-bold uppercase tracking-widest text-ink-mute mb-4">{g}</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {FEATURES.filter((f) => f.group === g).map((f) => (
          <a href={`/features/${f.slug}`} class="card hover:shadow-lift hover:border-brand-400 transition">
            <div class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name={f.icon} class="w-6 h-6" /></div>
            <h3 class="mt-4 font-semibold text-lg">{f.name}</h3>
            <p class="mt-2 text-ink-soft text-[15px]">{f.blurb}</p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-700">Learn more <Icon name="arrow" class="w-4 h-4" /></span>
          </a>
        ))}
      </div>
    </section>
  ))}
  <CTA />
</Layout>
