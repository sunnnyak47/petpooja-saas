---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Terms of Service">
  <section class="container-x py-16 max-w-3xl">
    <h1 class="h2">Terms of Service</h1>
    <p class="text-ink-soft mt-3">Last updated: {new Date().toLocaleDateString()}</p>
    <p class="mt-4 text-ink-soft">This is a placeholder Terms of Service for the MSRM marketing site. Replace with your reviewed legal copy before launch — covering acceptable use, subscription terms, billing, liability, and governing law (note your India/Australia entities).</p>
    <p class="mt-6 text-sm"><a href="/" class="text-brand-700 underline">← Back home</a></p>
  </section>
</Layout>
