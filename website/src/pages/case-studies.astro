---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { CASE_STUDIES } from '../data/site';
---
<Layout title="Case Studies" description="How Australian restaurants run leaner and faster on MSRM.">
  <section class="container-x pt-16 pb-8 text-center max-w-2xl mx-auto">
    <span class="eyebrow">Case studies</span>
    <h1 class="h1 text-4xl sm:text-5xl mt-3">Results restaurants see.</h1>
    <p class="lead mt-4">Fewer tools, less reconciliation, faster service — right across Australia.</p>
  </section>

  <section class="container-x grid gap-6 md:grid-cols-3">
    {CASE_STUDIES.map((c) => (
      <article class="card flex flex-col">
        <div class="flex items-center gap-2">
          <span class="text-lg">🇦🇺</span>
          <div><h3 class="font-bold">{c.name}</h3><p class="text-xs text-ink-mute">{c.type}</p></div>
        </div>
        <p class="mt-3 text-ink-soft text-[15px]">{c.summary}</p>
        <div class="mt-4 grid grid-cols-3 gap-2">
          {c.metrics.map((m) => (
            <div class="rounded-lg bg-surface-alt border border-line p-2 text-center">
              <div class="text-lg font-extrabold text-brand-600">{m.v}</div>
              <div class="text-[11px] text-ink-mute leading-tight mt-0.5">{m.l}</div>
            </div>
          ))}
        </div>
        <blockquote class="mt-4 text-sm italic text-ink-soft border-l-2 border-brand-200 pl-3">“{c.quote}”</blockquote>
      </article>
    ))}
  </section>
  <p class="container-x mt-5 text-xs text-ink-mute">Representative examples — we’ll add named, verified customer stories as launches roll out.</p>
  <CTA title="Want results like these?" />
</Layout>
