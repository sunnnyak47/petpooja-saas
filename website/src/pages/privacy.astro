---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Privacy Policy">
  <section class="container-x py-16 max-w-3xl prose-sm">
    <h1 class="h2">Privacy Policy</h1>
    <p class="text-ink-soft mt-3">Last updated: {new Date().toLocaleDateString()}</p>
    <p class="mt-4 text-ink-soft">This is a placeholder Privacy Policy for the MSRM marketing site. Replace with your reviewed legal copy before launch. It should cover: what data you collect (demo form: name, email, phone, restaurant), how it's used (sales contact), cookies/analytics, data retention, third-party processors (analytics, CRM), and how to request deletion.</p>
    <h2 class="font-semibold mt-6">Contact</h2>
    <p class="text-ink-soft">For privacy requests, email hello@getmsrm.com.</p>
    <p class="mt-6 text-sm"><a href="/" class="text-brand-700 underline">← Back home</a></p>
  </section>
</Layout>
